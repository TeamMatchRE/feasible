# ── Database — brooke-identity Postgres (schema: feasible) ────────────────────
# Supabase SESSION or TRANSACTION pooler string (host ...pooler.supabase.com).
# URL-encode password specials ($ -> %24, @ -> %40, : -> %3A, / -> %2F).
# The `feasible` schema + PostGIS extension must exist — run `npm run db:migrate`.
DATABASE_URL=

# ── Supabase auth (brooke-identity project ref: xipcwxosjnvuoazbckfi) ─────────
# Browser/SSR clients — Google sign-in flows through these so RLS applies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Trusted server routes only. Never shipped to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Maps (Maps JS: drawing + geometry + places libraries) ──────────────
# Same key already used by dwell / solar-roofing-app. Public — restrict by
# HTTP referrer in the Google Cloud console (add localhost:3010 + the prod host).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3010
